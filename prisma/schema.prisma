generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  KASIR
  CUSTOMER
  OWNER
}

enum OrderType {
  ONLINE
  OFFLINE
}

enum Status {
  PENDING
  VERIFIED
  COMPLETED
  CANCELLED
}

model User {
  id        Int     @id @default(autoincrement())
  username  String  @unique
  email     String? @unique
  password  String
  role      Role

  phone   String?
  address String?

  isMember         Boolean  @default(false)
  membershipStatus String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactionsAsCashier Transaction[] @relation("CashierTransaction")
  transactionsAsCustomer Transaction[] @relation("CustomerTransaction")
  @@map("users")
}

model Supplier {
  id            Int      @id @default(autoincrement())
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  purchases Purchase[]
  @@map("suppliers")
}

model Drug {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  stock       Int
  unit        String
  price       Float
  expiredDate DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactionDetails TransactionDetail[]
  purchaseDetails    PurchaseDetail[]
  components         CustomMedicineComponent[]

  @@map("drugs")
}

model CustomMedicine {
  id        Int      @id @default(autoincrement())
  name      String
  price     Float
  stock     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  components CustomMedicineComponent[]
  transactionDetails TransactionDetail[]

  @@map("custom_medicines")
}

model CustomMedicineComponent {
  id Int @id @default(autoincrement())

  customMedicineId Int
  drugId           Int
  quantity         Int
  unit             String

  customMedicine CustomMedicine @relation(fields: [customMedicineId], references: [id], onDelete: Cascade)
  drug           Drug           @relation(fields: [drugId], references: [id], onDelete: Restrict)

  @@index([customMedicineId])
  @@index([drugId])
  @@map("custom_medicine_components")
}

model Transaction {
  id                   Int       @id @default(autoincrement())
  orderCode            String    @unique @default(cuid())
  type                 OrderType
  status               Status    @default(PENDING)
  totalPrice           Float
  paymentProofImageUrl String?
  prescriptionImageUrl String?
  usageInstructions    String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  cashierId  Int?
  customerId Int?

  cashier  User? @relation("CashierTransaction", fields: [cashierId], references: [id], onDelete: SetNull)
  customer User? @relation("CustomerTransaction", fields: [customerId], references: [id], onDelete: SetNull)

  details TransactionDetail[]

  @@index([type])
  @@index([status])
  @@index([cashierId])
  @@index([customerId])
  @@map("transactions")
}

model TransactionDetail {
  id Int @id @default(autoincrement())

  transactionId    Int
  drugId           Int?
  customMedicineId Int?

  quantity  Int
  unitPrice Float
  subtotal  Float

  componentsSnapshot String?  // JSON snapshot komposisi racikan saat dibeli

  transaction    Transaction     @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  drug           Drug?           @relation(fields: [drugId], references: [id], onDelete: SetNull)
  customMedicine CustomMedicine? @relation(fields: [customMedicineId], references: [id], onDelete: SetNull)

  @@index([transactionId])
  @@index([drugId])
  @@index([customMedicineId])
  @@map("transaction_details")
}

model Purchase {
  id         Int      @id @default(autoincrement())
  purchaseCode String  @unique @default(cuid())
  totalPrice Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  supplierId Int
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)

  details PurchaseDetail[]

  @@index([supplierId])
  @@map("purchases")
}

model PurchaseDetail {
  id Int @id @default(autoincrement())

  purchaseId Int
  drugId     Int
  quantity   Int
  unitPrice  Float
  subtotal   Float

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  drug     Drug     @relation(fields: [drugId], references: [id], onDelete: Restrict)

  @@index([purchaseId])
  @@index([drugId])
  @@map("purchase_details")
}